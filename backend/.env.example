CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Coach chat model. NVIDIA NIM (https://build.nvidia.com). Kept server-side
# only, never exposed to the browser, since NVIDIA's API rejects direct
# browser calls (no CORS on the response) and the key is billable per token.
NVIDIA_API_KEY=<your-nvidia-nim-api-key>

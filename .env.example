# Supabase project credentials — get these from your Supabase dashboard
# Project Settings > API
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Market data for the Portfolio page. Both are free and called directly from the
# browser, so no separate backend server is required.
# Finnhub (https://finnhub.io, ~60 req/min): live stock/ETF quotes + symbol search.
VITE_FINNHUB_API_KEY=<your-finnhub-api-key>
# Twelve Data (https://twelvedata.com, 8 req/min): trend-chart history + crypto quotes.
VITE_TWELVEDATA_API_KEY=<your-twelvedata-api-key>

# Backend URL for the coach chat (POST /api/coach). The backend proxies chat
# completions to NVIDIA NIM and holds NVIDIA_API_KEY server-side (see
# backend/.env.example) since NVIDIA's API rejects direct browser calls.
# Run it with: cd backend && uvicorn main:app --reload --port 8000
# Without a reachable backend, the coach falls back to a rule-based offline mode.
VITE_API_URL=http://localhost:8000
